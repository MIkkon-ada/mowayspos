# ===== 后端 FastAPI Dockerfile =====
FROM python:3.12-slim

WORKDIR /app

# 安装 Python 依赖
COPY bowei_ai_dashboard/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制后端代码
COPY bowei_ai_dashboard/ .

# 暴露端口
EXPOSE 8008

# 启动命令
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8008"]
