# The environment and target database must always be explicit.
APP_ENV=development
DATABASE_URL=sqlite:///D:/replace-with-absolute-path/runtime.db

# Semicolon-separated on Windows; os.pathsep-separated on other platforms.
PROTECTED_DATABASE_PATHS=

# Leave these empty unless following the documented exact-authorization procedure.
ALLOW_DEV_SCHEMA_CREATE_ALL=
ALLOW_PROTECTED_DATABASE_MIGRATION=
ALLOW_TEST_MEMORY_DATABASE=

# DATABASE_URL must be explicit and SQLite paths must be absolute.
# Never point tests at a repository or production database.
# Protected migrations require a separate verified backup and human authorization.
# ALLOW_DEV_SCHEMA_CREATE_ALL must never be enabled in production.
